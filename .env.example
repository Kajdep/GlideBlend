# APP_URL: The public URL where this app is hosted.
# Used for self-referential links in robots.txt and sitemap.xml.
APP_URL="MY_APP_URL"

# VITE_GOOGLE_TAG_ID: Google tag (gtag.js) measurement ID for analytics.
# Obtain from Google Analytics > Admin > Data Streams > Measurement ID.
# When set, the gtag.js snippet is loaded automatically on page load.
VITE_GOOGLE_TAG_ID=""
